{
  "manifest_version": 2,
  "name": "Altered Decklist Retrieval Tool",
  "version": "1.0.0",
  "description": "Extraction de decklists depuis le site Altered.gg",

  "permissions": [
    "storage",
    "https://api.altered.gg/*",
    "https://www.altered.gg/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.altered.gg/*/decks*"],
      "js": ["src/content.js"],
      "css": ["src/style.css"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "scripts": ["src/background.js"]
  },

  "browser_action": {
    "default_title": "Decklists Extractor"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "altered-deck-retrieval-tool@addons.mozilla.org",
      "strict_min_version": "109.0",
      "data_collection_permissions": { "required": ["websiteContent"] }
    }
  },

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}